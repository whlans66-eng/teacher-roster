# =====================================================
# 🔒 安全：絕對不要提交這些檔案到 Git
# =====================================================

# 環境變數（包含資料庫帳密、JWT Secret）
.env
.env.local
.env.production
*.env

# 資料庫檔案
*.sqlite
*.db
database/data/*
!database/data/.gitkeep

# 允許資料庫初始化 SQL
!database/init/*.sql

# Docker volumes
docker-compose.override.yml
mysql-data/

# =====================================================
# Node.js / Backend
# =====================================================
backend/node_modules/
backend/dist/
backend/build/
backend/.env
backend/logs/*.log
!backend/logs/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# =====================================================
# React / Frontend
# =====================================================
frontend-new/node_modules/
frontend-new/dist/
frontend-new/build/
frontend-new/.env
frontend-new/.vite/

# =====================================================
# 編輯器 / IDE
# =====================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =====================================================
# 日誌和臨時檔案
# =====================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.pid
*.seed
*.pid.lock

# =====================================================
# 測試覆蓋率
# =====================================================
coverage/
.nyc_output/

# =====================================================
# 舊版檔案（保留在 repo 中但不追蹤更新）
# =====================================================
# archived/ 目錄已經在 Git 中，所以不加入 .gitignore
backend/local.settings.json
